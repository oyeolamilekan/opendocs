# Convex
# Convex deployment name
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=

# Convex HTTP actions URL, ending in .convex.site
VITE_CONVEX_SITE_URL=

# Public URL of this TanStack Start application
VITE_SITE_URL=http://localhost:3000

# Root domain used for project documentation subdomains.
# Local example: http://<project-slug>.localhost:3000
VITE_PUBLIC_DOCS_ROOT_DOMAIN=localhost

# Vercel AI Gateway key used by the default Gateway runtime
AI_GATEWAY_API_KEY=

# Server-only secret used to encrypt project-level AI provider API keys
AI_KEY_ENCRYPTION_SECRET=

# Set these with `bunx convex env set`, not in this file:
# BETTER_AUTH_SECRET=
# SITE_URL=http://localhost:3000
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001
